<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="RoyalBakeryCashier.Pages.GRNPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="{StaticResource PageBg}"
    Shell.NavBarIsVisible="False"
    NavigationPage.HasNavigationBar="False"
    Title="GRN Management">

    <Grid RowDefinitions="Auto,*" Padding="20" RowSpacing="12">

        <!-- HEADER -->
        <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
            <Label Text="Goods Received Notes" FontSize="22" FontAttributes="Bold" TextColor="White" VerticalOptions="Center"/>
            <HorizontalStackLayout Grid.Column="1" Spacing="8">
                <Button Text="+ New GRN"
                        FontSize="13" HeightRequest="36" Padding="14,0" CornerRadius="8"
                        BackgroundColor="{StaticResource CatDrinks}" TextColor="White"
                        Clicked="NewGRN_Clicked"/>
                <Button Text="Close"
                        FontSize="13" HeightRequest="36" Padding="12,0" CornerRadius="8"
                        BackgroundColor="{StaticResource CancelBtn}" TextColor="White"
                        Clicked="Close_Clicked"/>
            </HorizontalStackLayout>
        </Grid>

        <!-- GRN LIST + NEW GRN FORM side-by-side -->
        <Grid Grid.Row="1" ColumnDefinitions="1.2*,*" ColumnSpacing="12">

            <!-- LEFT: GRN List -->
            <Frame BackgroundColor="{StaticResource CardBg}" Padding="10" CornerRadius="12" BorderColor="{StaticResource Gray600}">
                <Grid RowDefinitions="Auto,*">
                    <Label Text="Recent GRNs" FontSize="16" FontAttributes="Bold" TextColor="White" Margin="0,0,0,8"/>
                    <CollectionView Grid.Row="1" x:Name="GRNListView" VerticalOptions="FillAndExpand">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame Padding="10,8" Margin="0,3" BackgroundColor="{StaticResource ItemRowBg}" CornerRadius="8" BorderColor="{StaticResource Gray600}">
                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="2">
                                        <Label Text="{Binding GRNNumber}" FontSize="15" FontAttributes="Bold" TextColor="White"/>
                                        <Label Grid.Row="1" Text="{Binding DateFormatted}" FontSize="11" TextColor="{StaticResource Gray300}"/>
                                        <Label Grid.Column="1" Text="{Binding ItemCountText}" FontSize="13" TextColor="{StaticResource TotalHighlight}" VerticalOptions="Center"/>
                                        <Button Grid.Row="1" Grid.Column="1" Text="View"
                                                FontSize="11" HeightRequest="28" WidthRequest="60" Padding="0" CornerRadius="6"
                                                BackgroundColor="{StaticResource CatBread}" TextColor="White"
                                                CommandParameter="{Binding GRNId}" Clicked="ViewGRN_Clicked"/>
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                        <CollectionView.EmptyView>
                            <Label Text="No GRNs yet" FontSize="14" TextColor="{StaticResource Gray400}" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </CollectionView.EmptyView>
                    </CollectionView>
                </Grid>
            </Frame>

            <!-- RIGHT: New GRN Form / GRN Detail -->
            <Frame Grid.Column="1" BackgroundColor="{StaticResource CardBg}" Padding="12" CornerRadius="12" BorderColor="{StaticResource Gray600}">
                <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="10">

                    <Label x:Name="FormTitle" Text="New GRN" FontSize="18" FontAttributes="Bold" TextColor="White"/>

                    <!-- Item selection row -->
                    <Grid Grid.Row="1" ColumnDefinitions="*,80,80,Auto" ColumnSpacing="6">
                        <Picker x:Name="MenuItemPicker"
                                Title="Select Item"
                                TextColor="White"
                                TitleColor="{StaticResource Gray400}"
                                BackgroundColor="{StaticResource InputBg}"/>
                        <Entry Grid.Column="1" x:Name="GRNQtyEntry"
                               Placeholder="Qty" PlaceholderColor="{StaticResource Gray400}"
                               TextColor="White" BackgroundColor="{StaticResource InputBg}"
                               Keyboard="Numeric"/>
                        <Entry Grid.Column="2" x:Name="GRNCostEntry"
                               Placeholder="Cost" PlaceholderColor="{StaticResource Gray400}"
                               TextColor="White" BackgroundColor="{StaticResource InputBg}"
                               Keyboard="Numeric"/>
                        <Button Grid.Column="3" Text="Add"
                                FontSize="13" HeightRequest="38" Padding="12,0" CornerRadius="6"
                                BackgroundColor="{StaticResource CatDrinks}" TextColor="White"
                                Clicked="AddGRNItem_Clicked"/>
                    </Grid>

                    <!-- GRN Items list -->
                    <CollectionView Grid.Row="2" x:Name="GRNItemsView" VerticalOptions="FillAndExpand">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame Padding="8,5" Margin="0,2" BackgroundColor="{StaticResource ItemRowBg}" CornerRadius="6" BorderColor="{StaticResource Gray600}">
                                    <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
                                        <Label Text="{Binding ItemName}" TextColor="White" FontSize="13" VerticalOptions="Center"/>
                                        <Label Grid.Column="1" Text="{Binding QuantityText}" TextColor="{StaticResource Gray300}" FontSize="12" VerticalOptions="Center"/>
                                        <Label Grid.Column="2" Text="{Binding CostText}" TextColor="{StaticResource TotalHighlight}" FontSize="12" VerticalOptions="Center"/>
                                        <Button Grid.Column="3" Text="X"
                                                WidthRequest="28" HeightRequest="28" Padding="0" FontSize="12" CornerRadius="4"
                                                BackgroundColor="{StaticResource CatSpecials}" TextColor="White"
                                                CommandParameter="{Binding .}" Clicked="RemoveGRNItem_Clicked"/>
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                        <CollectionView.EmptyView>
                            <Label Text="Add items above" FontSize="12" TextColor="{StaticResource Gray400}" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </CollectionView.EmptyView>
                    </CollectionView>

                    <!-- Save GRN button -->
                    <Button Grid.Row="3" x:Name="SaveGRNBtn" Text="Save GRN"
                            FontSize="16" FontAttributes="Bold" HeightRequest="48" CornerRadius="10"
                            BackgroundColor="{StaticResource PlaceOrderBtn}" TextColor="White"
                            Clicked="SaveGRN_Clicked"/>
                </Grid>
            </Frame>
        </Grid>
    </Grid>
</ContentPage>
